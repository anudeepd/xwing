{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "react": ["scripts/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["scripts/node_modules/@types/react/jsx-runtime.d.ts"],
      "react/jsx-dev-runtime": ["scripts/node_modules/@types/react/jsx-dev-runtime.d.ts"],
      "react-dom/*": ["scripts/node_modules/@types/react-dom/*"]
    },
    "typeRoots": ["scripts/node_modules/@types"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": ["xwing/frontend/src/**/*.ts", "xwing/frontend/src/**/*.tsx"]
}
